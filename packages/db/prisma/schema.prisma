// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  notionId  String?  // Notion people property ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  pairAsUser1    Pair?   @relation("User1")
  pairAsUser2    Pair?   @relation("User2")
  ownedTasks     TaskMirror[]
  settings       Settings?
}

model Pair {
  id        String   @id @default(cuid())
  user1Id   String   @unique
  user2Id   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user1        User          @relation("User1", fields: [user1Id], references: [id])
  user2        User          @relation("User2", fields: [user2Id], references: [id])
  notionConfig NotionConfig?
  settings     Settings?
}

model NotionConfig {
  id                String   @id @default(cuid())
  pairId            String   @unique
  databaseId        String
  integrationToken  String   // encrypted in production
  lastSyncAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  pair Pair @relation(fields: [pairId], references: [id])
}

model TaskMirror {
  id             String    @id @default(cuid())
  notionId       String    @unique
  title          String
  status         String    // 'Todo' | 'In Progress' | 'Done'
  dueDate        DateTime?
  ownerId        String
  lastEditedTime DateTime
  notionUrl      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  // Relations
  owner      User         @relation(fields: [ownerId], references: [id])
  taskEvents TaskEvent[]
}

model TaskEvent {
  id               String   @id @default(cuid())
  taskMirrorId     String
  eventType        String   // 'created' | 'status_changed' | 'completed'
  previousStatus   String?
  newStatus        String
  idempotencyKey   String   @unique
  processedAt      DateTime?
  createdAt        DateTime @default(now())
  
  // Relations
  taskMirror    TaskMirror     @relation(fields: [taskMirrorId], references: [id])
  notifications Notification[]
}

model Notification {
  id           String    @id @default(cuid())
  taskEventId  String
  channel      String    // 'whatsapp' | 'email' | 'web'
  status       String    // 'pending' | 'sent' | 'failed'
  sentAt       DateTime?
  retryCount   Int       @default(0)
  lastError    String?
  messageId    String?   // external message ID
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  taskEvent TaskEvent @relation(fields: [taskEventId], references: [id])
}

model Settings {
  id                    String   @id @default(cuid())
  pairId                String?  @unique
  userId                String?  @unique
  timezone              String   @default("Asia/Kolkata")
  warningTime           String   @default("20:00") // HH:mm format
  summaryTime           String   @default("23:55") // HH:mm format
  whatsappGroupJid      String?
  notificationTemplates String   @default("{}") // JSON object with template strings
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  pair Pair? @relation(fields: [pairId], references: [id])
  user User? @relation(fields: [userId], references: [id])
}
