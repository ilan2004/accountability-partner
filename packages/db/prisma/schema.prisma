generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  name          String?
  notionId      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  pairAsUser1   Pair?        @relation("User1")
  pairAsUser2   Pair?        @relation("User2")
  settings      Settings?
  ownedTasks    TaskMirror[]
}

model Pair {
  id           String        @id @default(uuid())
  user1Id      String        @unique
  user2Id      String        @unique
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  notionConfig NotionConfig?
  user1        User          @relation("User1", fields: [user1Id], references: [id])
  user2        User          @relation("User2", fields: [user2Id], references: [id])
  settings     Settings?
}

model NotionConfig {
  id               String    @id @default(uuid())
  pairId           String    @unique
  databaseId       String
  integrationToken String
  lastSyncAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  pair             Pair      @relation(fields: [pairId], references: [id])
}

model TaskMirror {
  id             String      @id @default(uuid())
  notionId       String      @unique
  title          String
  status         String
  dueDate        DateTime?
  ownerId        String
  lastEditedTime DateTime
  notionUrl      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  taskEvents     TaskEvent[]
  owner          User        @relation(fields: [ownerId], references: [id])
}

model TaskEvent {
  id             String         @id @default(uuid())
  taskMirrorId   String
  eventType      String
  previousStatus String?
  newStatus      String
  idempotencyKey String         @unique
  processedAt    DateTime?
  createdAt      DateTime       @default(now())
  notifications  Notification[]
  taskMirror     TaskMirror     @relation(fields: [taskMirrorId], references: [id])
}

model Notification {
  id          String    @id @default(uuid())
  taskEventId String
  channel     String
  status      String
  sentAt      DateTime?
  retryCount  Int       @default(0)
  lastError   String?
  messageId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  taskEvent   TaskEvent @relation(fields: [taskEventId], references: [id])
}

model Settings {
  id                    String   @id @default(uuid())
  pairId                String?  @unique
  userId                String?  @unique
  timezone              String   @default("Asia/Kolkata")
  warningTime           String   @default("20:00")
  summaryTime           String   @default("23:55")
  whatsappGroupJid      String?
  notificationTemplates String   @default("{}")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  pair                  Pair?    @relation(fields: [pairId], references: [id])
  user                  User?    @relation(fields: [userId], references: [id])
}
